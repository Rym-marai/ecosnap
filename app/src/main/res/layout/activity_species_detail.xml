<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN: Species Detail
    Purpose: Shows AI-identified species info:
             image, name, conservation status, description,
             habitat, ecological role, threats.
             EcoPoints toast, Save to Journal button.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_surface">

    <!-- ── Top Bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:backgroundTint="@color/background_surface"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Species Detail"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Species Image ── -->
            <ImageView
                android:id="@+id/ivSpeciesPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:src="@drawable/camelion_ord"
                android:background="@color/green_light" />

            <!-- ── EcoPoints Earned Banner ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@color/green_primary"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌟 +25 EcoPoints Earned!"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

            </LinearLayout>

            <!-- ── Name + Status ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvSpeciesName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chameleon ordinaire"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Conservation Status Badge -->
                    <TextView
                        android:id="@+id/tvConservationStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vulnerable"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_vu_text"
                        android:background="@color/status_vu_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvScientificName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chamaeleo chamaeleon"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- ── Description ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A slow-moving lizard known for its ability to change color. Found in northern Tunisia in shrubby coastal areas and gardens."
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- ── Habitat ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Habitat"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvHabitat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Coastal Mediterranean scrubland, gardens, and dry open forests in northern Tunisia and nearby regions."
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- ── Ecological Role ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ecological Role"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvEcologicalRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Controls insect populations through predation. Acts as prey for larger raptors and snakes."
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- ── Threats ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/status_en_bg"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️  Threats"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_en_text"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvThreats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Habitat loss due to urbanization, illegal pet trade, and use of pesticides that reduce prey availability."
                    android:textSize="13sp"
                    android:textColor="@color/status_en_text"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom Action Button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <Button
            android:id="@+id/btnSaveToJournal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Save to Journal"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/green_primary" />

    </LinearLayout>

</LinearLayout>
